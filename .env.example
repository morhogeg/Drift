# Drift environment variables.
#
# Production is bring-your-own-key: users enter their own key in the app, so
# leave these EMPTY for any committed file and for release builds.
#
# For LOCAL DEVELOPMENT, put your personal testing key in `.env.development.local`
# (gitignored, loaded only by `vite` / `npm run dev`, never by `vite build`):
#
#   VITE_GEMINI_API_KEY=AIza...        # Google AI Studio: https://aistudio.google.com
#   VITE_OPENROUTER_API_KEY=sk-or-...  # optional: https://openrouter.ai/keys

VITE_GEMINI_API_KEY=
VITE_OPENROUTER_API_KEY=

# Firebase (optional — enables cloud accounts + backup/restore)
# Leave these blank to keep Drift fully local-first: when any of the values
# below is missing, the Account/cloud-sync feature stays disabled and the app
# behaves exactly as before. Fill them in (Firebase console → Project settings →
# your web app) to turn the feature on.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
