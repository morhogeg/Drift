# OpenRouter API Configuration
# Get your API key from https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here

# Firebase (optional — enables cloud accounts + backup/restore)
# Leave these blank to keep Drift fully local-first: when any of the values
# below is missing, the Account/cloud-sync feature stays disabled and the app
# behaves exactly as before. Fill them in (Firebase console → Project settings →
# your web app) to turn the feature on.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=