# Drift environment variables.
#
# Production is bring-your-own-key: users enter their own key in the app, so
# leave these EMPTY for any committed file and for release builds.
#
# For LOCAL DEVELOPMENT, put your personal testing key in `.env.development.local`
# (gitignored, loaded only by `vite` / `npm run dev`, never by `vite build`):
#
#   VITE_GEMINI_API_KEY=AIza...        # Google AI Studio: https://aistudio.google.com
#   VITE_OPENROUTER_API_KEY=sk-or-...  # optional: https://openrouter.ai/keys

VITE_GEMINI_API_KEY=
VITE_OPENROUTER_API_KEY=
