rules_version = '2';

// Drift — Firestore security rules.
//
// Model: each signed-in user owns exactly one subtree, users/{uid}/**.
// v1 stores a single cloud backup blob at users/{uid}/backup/current.
// A user may only read/write their own subtree; everything else is denied.
//
// NOTE: these rules intentionally do NOT validate the backup payload shape —
// the client strips API keys before upload (see cloudSync.ts). Do not rely on
// rules for that; the stripping + assertion test is the guarantee.

service cloud.firestore {
  match /databases/{database}/documents {

    // A user's private subtree. uid must match the authenticated user.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
