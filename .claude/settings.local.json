{
  "permissions": {
    "allow": [
      "Bash(npm create:*)",
      "Bash(rm:*)",
      "Bash(mkdir:*)",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(ls:*)",
      "Bash(npx tailwindcss init:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(npm uninstall:*)",
      "Bash(npm run build:*)",
      "Bash(npm run build)",
      "Bash(npx cap sync ios)",
      "Read(/var/folders/**)"
    ],
    "deny": []
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /Users/morhogeg/Drift && pgrep -f 'vite' > /dev/null && echo '⚡ Live reload active — skipping build' || (npm run build && npx cap sync ios)"
          }
        ]
      }
    ]
  }
}
